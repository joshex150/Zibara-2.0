# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─────────────────────────────────────────────
# AUTHENTICATION (NextAuth)
# ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Auth.js v5 (if used alongside NextAuth)
AUTH_SECRET=your-auth-secret
AUTH_TRUST_HOST=true

# ─────────────────────────────────────────────
# ADMIN CREDENTIALS
# ─────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-admin-password
ADMIN_NAME=Admin

# ─────────────────────────────────────────────
# PAYMENT — FLUTTERWAVE
# ─────────────────────────────────────────────
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_HASH=your-flutterwave-webhook-secret-hash

# ─────────────────────────────────────────────
# PAYMENT — PAYSTACK
# ─────────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret-key

# ─────────────────────────────────────────────
# EMAIL (SMTP — e.g. Gmail, Resend, Postmark)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM=ZIBARASTUDIO <studio@zibarastudio.com>

# ─────────────────────────────────────────────
# FILE UPLOADS — CLOUDINARY
# ─────────────────────────────────────────────
CLOUDINARY_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
